# Kopiere diese Datei nach ".env" und trage deine echten Werte ein.
# Die .env-Datei wird durch .gitignore vom Repository ausgeschlossen.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/xxxxxxxxxxxxxxxxxxxx

# Optional: nur noetig fuer die automatischen Status-Reaktionen an jede Meldung.
# Ein Webhook allein kann keine Reaktionen setzen - dafuer braucht es einen Bot.
# Ohne diesen Token kommen die Meldungen trotzdem, nur ohne Reaktionen.
DISCORD_BOT_TOKEN=
